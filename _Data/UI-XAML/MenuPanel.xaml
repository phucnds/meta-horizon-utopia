<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  x:Name="ComponentRoot" d:DesignWidth="1714" d:DesignHeight="3711">
  <Image Source="/Root;component/_Data/Images/Home BG.png" Stretch="Fill"/>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="1856*"/>
      <RowDefinition Height="1855*"/>
    </Grid.RowDefinitions>
    <Image Source="/Root;component/_Data/Images/Group 8.png" Stretch="None"/>
    <Grid Row="1">
      <Button HorizontalAlignment="Center" VerticalAlignment="Bottom" Padding="0,0,0,0" Height="200" Width="500" Margin="0,0,0,300" Command="{Binding Path=events.onTapEvent}">
        <Grid Width="600" HorizontalAlignment="Center" VerticalAlignment="Center" Height="400">
          <Image Source="/Root;component/_Data/Images/Battle Button (2).png"/>
        </Grid>
      </Button>
      <Button HorizontalAlignment="Center" VerticalAlignment="Bottom" Padding="0,0,0,0" Height="200" Width="500" Margin="0,0,0,600" Command="{Binding Path=events.onTapEvent2}">
        <Grid Width="600" HorizontalAlignment="Center" VerticalAlignment="Center" Height="400">
          <Image Source="/Root;component/_Data/Images/Battle Button (1).png"/>
        </Grid>
      </Button>
    </Grid>
  </Grid>
</Grid>
