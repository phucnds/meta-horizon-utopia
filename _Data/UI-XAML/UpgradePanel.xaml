<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  x:Name="ComponentRoot" d:DesignWidth="1714" d:DesignHeight="3711">
  <Rectangle Stroke="#FF000000">
    <Rectangle.Fill>
      <SolidColorBrush Color="#FF1D1D1D" Opacity="0.8"/>
    </Rectangle.Fill>
  </Rectangle>
  <Grid Height="1586" Width="1318">
    <Image Source="/Root;component/_Data/Images/bgContainUpgrade.png"/>
    <Button VerticalAlignment="Top" HorizontalAlignment="Right" Command="{Binding Path=events.onHide}" Width="100" Height="80" Margin="0,32,32,0" ClickMode="Press">
      <Button.Background>
        <SolidColorBrush Color="#FF4B5258" Opacity="0"/>
      </Button.Background>
      <Grid Height="100" Width="100" Margin="-50,-180,-50,-180">
        <Image Source="/Root;component/_Data/Images/btnClose.png"/>
      </Grid>
    </Button>
    <Grid Margin="0,200,0,60">
      <Grid.RowDefinitions>
        <RowDefinition Height="332*"/>
        <RowDefinition Height="331*"/>
        <RowDefinition Height="332*"/>
        <RowDefinition Height="331*"/>
      </Grid.RowDefinitions>
      <Grid x:Name="dameContain">
        <Image Source="/Root;component/_Data/Images/Group 4.png" Margin="80,0,80,0"/>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" Margin="132,179,0,0" FontSize="28" Text="{Binding Path=levelDame}"/>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" FontSize="36" Margin="334,-0,-0,144" Text="Damage" Stroke="#FF000000" StrokeThickness="4"/>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" FontSize="36" Margin="334,104,-0,-0" Text="{Binding Path=valueDame}"/>
        <Button VerticalAlignment="Center" HorizontalAlignment="Right" Padding="0,0,0,0" Height="120" Margin="0,0,180,0" Width="240" Command="{Binding Path=events.onDame}">
          <Button.Background>
            <SolidColorBrush Color="#FF000000" Opacity="0"/>
          </Button.Background>
          <Grid Margin="-60,-20,-60,-20">
            <Image Source="/Root;component/_Data/Images/btnGreen.png" Stretch="Fill"/>
            <Image Source="/Root;component/_Data/Images/Currency.png" VerticalAlignment="Center" HorizontalAlignment="Left" Width="60" Height="60" Margin="20,0,0,0"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" Margin="100,0,30,0" Stroke="#FF181818" StrokeThickness="4" FontSize="36" Text="{Binding Path=costDame}"/>
          </Grid>
        </Button>
      </Grid>
      <Grid x:Name="critContain" Row="1">
        <Image Margin="80,0,80,0" Source="/Root;component/_Data/Images/Group 6.png"/>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" Margin="132,179,0,0" FontSize="28" Text="{Binding Path=levelCrit}"/>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" FontSize="36" Margin="334,-0,-0,144" Text="Critical Chance" StrokeThickness="4" Stroke="#FF000000"/>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" FontSize="36" Margin="334,104,-0,-0" Text="{Binding Path=valueCrit}"/>
        <Button VerticalAlignment="Center" HorizontalAlignment="Right" Padding="0,0,0,0" Height="120" Margin="0,0,180,0" Width="240" Command="{Binding Path=events.onCrit}">
          <Button.Background>
            <SolidColorBrush Color="#FF000000" Opacity="0"/>
          </Button.Background>
          <Grid Margin="-60,-20,-60,-20">
            <Image Source="/Root;component/_Data/Images/btnGreen.png" Stretch="Fill"/>
            <Image Source="/Root;component/_Data/Images/Currency.png" VerticalAlignment="Center" HorizontalAlignment="Left" Width="60" Height="60" Margin="20,0,0,0"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" Margin="100,0,30,0" Stroke="#FF181818" StrokeThickness="4" FontSize="36" Text="{Binding Path=costCrit}"/>
          </Grid>
        </Button>
      </Grid>
      <Grid x:Name="atkSpdContain" Row="2">
        <Image Margin="80,0,80,0" Source="/Root;component/_Data/Images/Group 5.png"/>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" Margin="132,179,0,0" FontSize="28" Text="{Binding Path=levelAtkspd}"/>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" FontSize="36" Margin="334,-0,-0,144" Text="Attack Speed" StrokeThickness="4" Stroke="#FF000000"/>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" FontSize="36" Margin="334,104,-0,-0" Text="{Binding Path=valueAtkspd}"/>
        <Button VerticalAlignment="Center" HorizontalAlignment="Right" Padding="0,0,0,0" Height="120" Margin="0,0,180,0" Width="240" Command="{Binding Path=events.onAtkspd}">
          <Button.Background>
            <SolidColorBrush Color="#FF000000" Opacity="0"/>
          </Button.Background>
          <Grid Margin="-60,-20,-60,-20">
            <Image Source="/Root;component/_Data/Images/btnGreen.png" Stretch="Fill"/>
            <Image Source="/Root;component/_Data/Images/Currency.png" VerticalAlignment="Center" HorizontalAlignment="Left" Width="60" Height="60" Margin="20,0,0,0"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" Margin="100,0,30,0" Stroke="#FF181818" StrokeThickness="4" FontSize="36" Text="{Binding Path=costAtkspd}"/>
          </Grid>
        </Button>
      </Grid>
      <Grid x:Name="hpContain" Row="3">
        <Image Margin="80,0,80,0" Source="/Root;component/_Data/Images/Group 7.png"/>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" Margin="132,179,0,0" FontSize="28" Text="{Binding Path=levelHP}"/>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" FontSize="36" Margin="334,-0,-0,144" Text="Health point" StrokeThickness="4" Stroke="#FF000000"/>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" FontSize="36" Margin="334,104,-0,-0" Text="{Binding Path=valueHP}"/>
        <Button VerticalAlignment="Center" HorizontalAlignment="Right" Padding="0,0,0,0" Height="120" Margin="0,0,180,0" Width="240" Command="{Binding Path=events.onHP}">
          <Button.Background>
            <SolidColorBrush Color="#FF000000" Opacity="0"/>
          </Button.Background>
          <Grid Margin="-60,-20,-60,-20">
            <Image Source="/Root;component/_Data/Images/btnGreen.png" Stretch="Fill"/>
            <Image Source="/Root;component/_Data/Images/Currency.png" VerticalAlignment="Center" HorizontalAlignment="Left" Width="60" Height="60" Margin="20,0,0,0"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Galindo" Margin="100,0,30,0" Stroke="#FF181818" StrokeThickness="4" FontSize="36" Text="{Binding Path=costHP}"/>
          </Grid>
        </Button>
      </Grid>
    </Grid>
  </Grid>
</Grid>
