<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  x:Name="ComponentRoot" d:DesignWidth="1714" d:DesignHeight="3711">
  <Image Source="/Root;component/_Data/Images/Home BG.png" Stretch="Fill"/>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="1856*"/>
      <RowDefinition Height="1855*"/>
    </Grid.RowDefinitions>
    <Image Source="/Root;component/_Data/Images/Group 8.png" Stretch="None"/>
    <Grid Row="1">
      <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Galindo" VerticalAlignment="Top" FontSize="120" Text="{Binding Path=dataString}"/>
    </Grid>
  </Grid>
</Grid>
