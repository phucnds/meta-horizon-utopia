<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignWidth="1920"
  d:DesignHeight="1080"
  x:Name="ComponentRoot">
  <ProgressBar Template="{DynamicResource CustomProgress}" Value="{Binding Path=healthPercentage}">
    <ProgressBar.Resources>
      <ResourceDictionary>
        <ControlTemplate x:Key="CustomProgress" TargetType="ProgressBar">
          <Grid>
            <Border x:Name="PART_Track" CornerRadius="15,15,15,15">
              <Panel.Background>
                <SolidColorBrush Color="#FF000000" Opacity="0.602"/>
              </Panel.Background>
            </Border>
            <Border x:Name="PART_Indicator" CornerRadius="15,15,15,15" Width="141" HorizontalAlignment="Left">
              <Panel.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                  <GradientStop Color="{Binding Path=primaryHealthColour}" Offset="0.427"/>
                  <GradientStop Color="{Binding Path=secondaryHealthColour}" Offset="0.595"/>
                </LinearGradientBrush>
              </Panel.Background>
            </Border>
            <Border x:Name="Outline" BorderThickness="5" CornerRadius="15,15,15,15" BorderBrush="#FF311900" Height="34" Width="216" Margin="-1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
        </ControlTemplate>
      </ResourceDictionary>
    </ProgressBar.Resources>
  </ProgressBar>
</Grid>
