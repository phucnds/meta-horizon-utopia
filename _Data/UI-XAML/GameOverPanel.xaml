<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  x:Name="ComponentRoot" d:DesignWidth="1714" d:DesignHeight="3711">
  <Rectangle Stroke="#FF000000">
    <Rectangle.Fill>
      <SolidColorBrush Color="#FF202020" Opacity="0.7"/>
    </Rectangle.Fill>
  </Rectangle>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="332*"/>
      <RowDefinition Height="1166*"/>
      <RowDefinition Height="422*"/>
    </Grid.RowDefinitions>
    <Grid>
      <Image Source="/Root;component/_Data/Images/Defeat.png" Stretch="None"/>
    </Grid>
    <Grid Row="1">
      <Image Source="/Root;component/_Data/Images/lose.png" Stretch="None"/>
    </Grid>
    <Grid Row="2">
      <Button VerticalAlignment="Bottom" HorizontalAlignment="Center" Width="300" Height="160" Margin="0,0,0,500" Command="{Binding Path=events.onTapUpgradeEvent}">
        <Grid Margin="-200,-50,-200,-50">
          <Image Source="/Root;component/_Data/Images/Battle Button (1).png"/>
        </Grid>
      </Button>
      <Button VerticalAlignment="Bottom" HorizontalAlignment="Center" Width="300" Height="160" Command="{Binding Path=events.onTapEvent}" Margin="0,0,0,200">
        <Grid Margin="-200,-50,-200,-50">
          <Image Source="/Root;component/_Data/Images/Battle Button.png"/>
        </Grid>
      </Button>
    </Grid>
  </Grid>
</Grid>
