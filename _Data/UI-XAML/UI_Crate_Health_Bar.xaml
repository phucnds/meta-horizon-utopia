<Component
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  x:Name="ComponentRoot" DataContext="CrateHealthUIModel" d:DataContext="CrateHealthUIModel Data 01" d:DesignWidth="1714" d:DesignHeight="3711">
    <Component.Resources>
        <ResourceDictionary>
            <ControlTemplate x:Key="ProgressBar_Crate_HealthBar" TargetType="ProgressBar">
                <Grid>
                    <Border x:Name="PART_Track" CornerRadius="15,15,15,15">
                        <Panel.Background>
                            <SolidColorBrush Color="#FF000000" Opacity="0.602"/>
                        </Panel.Background>
                    </Border>
                    <Border x:Name="PART_Indicator" CornerRadius="15,15,15,15" Width="141" HorizontalAlignment="Left">
                        <Panel.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="{Binding Path=primaryHealthColour}" Offset="0.427"/>
                                <GradientStop Color="{Binding Path=secondaryHealthColour}" Offset="0.595"/>
                            </LinearGradientBrush>
                        </Panel.Background>
                    </Border>
                    <Border x:Name="Outline" BorderThickness="5" CornerRadius="15,15,15,15" BorderBrush="#FF311900" Height="34" Width="216" Margin="-1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </ControlTemplate>
            <Color x:Key="Dark_Brown_Outline">#FF311900</Color>
            <Color x:Key="crate_health_100_1">#FF35CDFF</Color>
            <Color x:Key="crate_health_100_2">#FF1C89AD</Color>
        </ResourceDictionary>
    </Component.Resources>
    <Grid x:Name="Crate_Health" Grid.RowSpan="3" Grid.ColumnSpan="3" Opacity="{Binding Path=panelOpacity}" VerticalAlignment="Bottom" HorizontalAlignment="Center">
    <Grid.RowDefinitions>
      <RowDefinition Height="245*"/>
      <RowDefinition Height="590*"/>
      <RowDefinition Height="245*"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="116*"/>
      <ColumnDefinition Width="1688*"/>
      <ColumnDefinition Width="116*"/>
    </Grid.ColumnDefinitions>
    <Grid x:Name="root" Grid.Row="1" Grid.Column="1" Width="216" Height="103">
      <ProgressBar Template="{DynamicResource ProgressBar_Crate_HealthBar}" Value="{Binding Path=healthPercentage}" Foreground="{x:Null}" RenderTransformOrigin="0.5,0.5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
      <TextBlock x:Name="Health_Number" FontSize="34" Text="{Binding Path=healthAmountText}" Foreground="#FFFFFFFF" TextWrapping="Wrap" FontFamily="Roboto" FontWeight="DemiBold" StrokeThickness="7" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0">
        <TextBlock.Stroke>
          <SolidColorBrush Color="{DynamicResource Dark_Brown_Outline}"/>
        </TextBlock.Stroke>
      </TextBlock>
    </Grid>
  </Grid>
</Component>
