<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:system="clr-namespace:System;assembly=mscorlib"
  mc:Ignorable="d"
  x:Name="ComponentRoot" d:DesignWidth="1714" d:DesignHeight="3711">
  <Rectangle Stroke="#FF000000">
    <Rectangle.Fill>
      <SolidColorBrush Color="#FF202020" Opacity="0"/>
    </Rectangle.Fill>
  </Rectangle>
  <Grid Visibility="{Binding Path=textVisible}">
    <Grid.RowDefinitions>
      <RowDefinition Height="360*"/>
      <RowDefinition Height="1553*"/>
    </Grid.RowDefinitions>
    <Grid Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="779*"/>
        <RowDefinition Height="780*"/>
      </Grid.RowDefinitions>
      <Grid>
        <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" FontFamily="Galindo" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Wave completed" FontSize="120"/>
      </Grid>
    </Grid>
  </Grid>
  <Grid d:IsHidden="True" Visibility="{Binding Path=boostVisible}">
    <Grid.RowDefinitions>
      <RowDefinition Height="507*"/>
      <RowDefinition Height="1827*"/>
      <RowDefinition Height="140*"/>
    </Grid.RowDefinitions>
    <StackPanel Margin="-0,100">
      <TextBlock TextWrapping="Wrap" FontFamily="Anton" Text="Level up!" TextAlignment="Center" Foreground="#FF38FF00" VerticalAlignment="Top" FontSize="160"/>
      <TextBlock TextWrapping="Wrap" TextAlignment="Center" Text="Pick 1 booster" FontFamily="Galindo" Foreground="#FFFFFFFF" FontSize="80"/>
    </StackPanel>
    <StackPanel Grid.Row="1">
      <Grid x:Name="Item1" Height="800">
        <Button x:Name="btnCommon017" ClickMode="Press" Padding="0,0,0,0" Background="{x:Null}" Foreground="{x:Null}" BorderBrush="{x:Null}" Margin="500,60,500,60" Command="{Binding Path=events.onWaveTransitionTapOption1}">
          <Grid x:Name="Content017" Width="942" Height="680" Margin="-120,0,-120,0">
            <Image Source="/Root;component/_Data/Images/bg.png"/>
            <Image VerticalAlignment="Top" Margin="2,0,2,0" Source="{Binding Path=tierIcon1}"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Galindo" VerticalAlignment="Top" Margin="0,20,0,20" FontSize="58" Text="{Binding Path=tierTitle1}"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Galindo" VerticalAlignment="Top" StrokeThickness="6" Margin="-0,173,-0,-0" FontSize="52" Text="{Binding Path=itemName1}" Stroke="{Binding Path=outline1}"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Galindo" VerticalAlignment="Top" StrokeThickness="6" Stroke="#FF42533F" Margin="-0,481,-0,-0" FontSize="42" Text="{Binding Path=itemDes1}"/>
            <Image Margin="299,218,298,182" Width="140" Height="140" Source="{Binding Path=iconLink1}"/>
          </Grid>
        </Button>
      </Grid>
      <Grid x:Name="Item2" Height="800">
        <Button x:Name="btnCommon018" ClickMode="Press" Padding="0,0,0,0" Background="{x:Null}" Foreground="{x:Null}" BorderBrush="{x:Null}" Margin="500,60,500,60" Command="{Binding Path=events.onWaveTransitionTapOption2}">
          <Grid x:Name="Content018" Width="942" Height="680" Margin="-120,0,-120,0">
            <Image Source="/Root;component/_Data/Images/bg.png"/>
            <Image VerticalAlignment="Top" Margin="2,0,2,0" Source="{Binding Path=tierIcon2}"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Galindo" VerticalAlignment="Top" Margin="0,20,0,20" FontSize="58" Text="{Binding Path=tierTitle2}"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Galindo" VerticalAlignment="Top" StrokeThickness="6" Margin="-0,173,-0,-0" FontSize="52" Text="{Binding Path=itemName2}" Stroke="{Binding Path=outline2}"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Galindo" VerticalAlignment="Top" StrokeThickness="6" Stroke="#FF42533F" Margin="-0,481,-0,-0" FontSize="42" Text="{Binding Path=itemDes2}"/>
            <Image Margin="299,218,298,182" Width="140" Height="140" Source="{Binding Path=iconLink2}"/>
          </Grid>
        </Button>
      </Grid>
      <Grid x:Name="Item3" Height="800">
        <Button x:Name="btnCommon019" ClickMode="Press" Padding="0,0,0,0" Background="{x:Null}" Foreground="{x:Null}" BorderBrush="{x:Null}" Margin="500,60,500,60" Command="{Binding Path=events.onWaveTransitionTapOption3}">
          <Grid x:Name="Content019" Width="942" Height="680" Margin="-120,0,-120,0">
            <Image Source="/Root;component/_Data/Images/bg.png"/>
            <Image VerticalAlignment="Top" Margin="2,0,2,0" Source="{Binding Path=tierIcon3}"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Galindo" VerticalAlignment="Top" Margin="0,20,0,20" FontSize="58" Text="{Binding Path=tierTitle3}"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Galindo" VerticalAlignment="Top" StrokeThickness="6" Margin="-0,173,-0,-0" FontSize="52" Text="{Binding Path=itemName3}" Stroke="{Binding Path=outline3}"/>
            <TextBlock Foreground="#FFFFFFFF" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Galindo" VerticalAlignment="Top" StrokeThickness="6" Stroke="#FF42533F" Margin="-0,481,-0,-0" FontSize="42" Text="{Binding Path=itemDes3}"/>
            <Image Margin="299,218,298,182" Width="140" Height="140" Source="{Binding Path=iconLink3}"/>
          </Grid>
        </Button>
      </Grid>
    </StackPanel>
  </Grid>
</Grid>
