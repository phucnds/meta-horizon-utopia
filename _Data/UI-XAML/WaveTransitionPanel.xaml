<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:system="clr-namespace:System;assembly=mscorlib"
  mc:Ignorable="d"
  x:Name="ComponentRoot" d:DesignWidth="1080" d:DesignHeight="1920">
  <Rectangle Stroke="#FF000000">
    <Rectangle.Fill>
      <SolidColorBrush Color="#FF202020" Opacity="0.7"/>
    </Rectangle.Fill>
  </Rectangle>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="360*"/>
      <RowDefinition Height="1553*"/>
    </Grid.RowDefinitions>
    <StackPanel>
      <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,100,0,0" FontFamily="Anton" Text="Level up!" TextAlignment="Center" Foreground="#FF38FF00" FontSize="100"/>
      <TextBlock FontSize="48" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Top" TextAlignment="Center" Text="Pick 1 booster" FontFamily="Galindo" Foreground="#FFFFFFFF"/>
    </StackPanel>
    <Grid Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="227*"/>
        <RowDefinition Height="1200*"/>
        <RowDefinition Height="227*"/>
      </Grid.RowDefinitions>
      <ListView Grid.RowSpan="3"/>
    </Grid>
  </Grid>
</Grid>
